# Copy this file to ".env" (just .env) and fill in ONLY the channels you want.
# Everything here is optional — desktop alerts and Discord/Slack work without it.

# --- Email alerts (optional) ---
# For Gmail: make an "app password" (not your real password) and use it here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL_TO=youraddress@gmail.com

# --- Discord/Slack webhook (optional) ---
# You can also paste this straight into the dashboard's Alerts panel instead.
DISCORD_WEBHOOK_URL=
